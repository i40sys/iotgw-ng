# ── Backups ────────────────────────────────────────────────
/BACKUP/

# ── Dependencies / build noise ─────────────────────────────
node_modules/
dist/
.DS_Store

# ── Independent subproject git repositories ────────────────
# These are managed by their own git remotes; required by this
# workspace but NOT tracked by the root orchestration repo.
/iotgw-ui/
/kms/
/supabase/
/ansible/netmaker/
/kestra/kestra-ansible-reporter/

# ── Kestra runtime volumes (internal storage, executions, DB) ─
# Kestra-managed working dir: execution history, KV store, Postgres
# data, and the namespace flow source (_files) — which is itself an
# independent git repo. Regenerated/synced — not tracked by root.
/kestra/db/
/kestra/logs/
/kestra/data/
# _files is a nested git repo (gitlink) — dir patterns don't catch it, so list explicitly
/kestra/data/main/iotgw-ng/_files

# ── Claude local (machine-specific) ────────────────────────
.claude/settings.local.json
