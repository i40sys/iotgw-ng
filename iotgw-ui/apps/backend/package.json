{
  "name": "@iotgw/backend",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "packageManager": "pnpm@10.6.3",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "tsx src/server.ts",
    "build": "esbuild src/server.ts --bundle --packages=external --platform=node --format=esm --outdir=dist --sourcemap",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest watch",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint --cache \"src/**/*.{ts,tsx,js}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "login": "pnpx supabase login",
    "generate": "pnpm --filter @iotgw/supabase-contract generate && pnpm --filter @iotgw/supabase-contract build"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/websocket": "^11.0.2",
    "@iotgw/supabase-contract": "workspace:*",
    "@supabase/supabase-js": "^2.49.5",
    "@trpc/client": "^11.1.2",
    "@trpc/server": "^11.1.2",
    "@types/pino": "^7.0.5",
    "fastify": "^5.3.3",
    "formdata-node": "^6.0.3",
    "pino": "^9.7.0",
    "supabase": "^2.23.4",
    "superjson": "^2.2.2",
    "tslib": "^2.8.1",
    "ws": "^8.18.2",
    "zod": "^3.25.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.19",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^2.1.8",
    "esbuild": "^0.25.4",
    "eslint": "^9.27.0",
    "pino-pretty": "^13.0.0",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^2.1.8"
  }
}
