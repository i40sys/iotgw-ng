# Supabase configuration
SUPABASE_URL=https://your-project-id.supabase.co

# Required: Service role key for backend operations (bypasses RLS)
# This key is mandatory as RLS policies only allow authenticated users
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Server configuration
PORT=3001
NODE_ENV=development

# Cosmian KMS — device SSH key generation (decision-010)
# Dev/compose: host URL; k8s: in-cluster service (http://cosmian-kms:9998)
KMS_URL=http://wsl.ymbihq.local:9998
# Reserved: bearer token for when the KMS enables authentication (none today)
# KMS_AUTH_TOKEN=your-kms-token-here