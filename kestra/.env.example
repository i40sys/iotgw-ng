# .env.example — TEMPLATE (committed).
# Real values live encrypted in secrets/kestra.enc.env (SOPS+age, decision-014).
# These are consumed by the cluster: deploy/kind/bootstrap.sh make_secrets turns
# secrets/kestra.enc.env into the `kestra-env` k8s Secret (envFrom on the kestra
# Deployment). pnpm-dev / local helper consumers render plaintext with
#   just secrets-render            (or: tools/secrets/secrets.sh render kestra)
# Do NOT put real secrets in this file.
# Kestra stack secrets (config lives in deploy/k8s/base/kestra/, not a compose file)
KESTRA_POSTGRES_PASSWORD=CHANGEME
KESTRA_GEMINI_API_KEY=CHANGEME
KESTRA_BASIC_AUTH_USERNAME=CHANGEME
KESTRA_BASIC_AUTH_PASSWORD=CHANGEME
