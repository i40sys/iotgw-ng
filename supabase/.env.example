# .env.example — TEMPLATE (committed).
# Real values live encrypted in secrets/supabase.enc.env. Render with:
#   tools/secrets/secrets.sh render supabase
# Do NOT put real secrets in this file.
############
# Secrets
# YOU MUST CHANGE THESE BEFORE GOING INTO PRODUCTION
############
PG_META_CRYPTO_KEY=CHANGEME
POOLER_DB_POOL_SIZE=CHANGEME
POSTGRES_PASSWORD=CHANGEME
JWT_SECRET=CHANGEME
ANON_KEY=CHANGEME
SERVICE_ROLE_KEY=CHANGEME
DASHBOARD_USERNAME=CHANGEME
DASHBOARD_PASSWORD=CHANGEME
SECRET_KEY_BASE=CHANGEME
VAULT_ENC_KEY=CHANGEME
############
# Database - You can change these to any PostgreSQL database that has logical replication enabled.
############
POSTGRES_HOST=CHANGEME
POSTGRES_DB=CHANGEME
POSTGRES_PORT=CHANGEME
# default user is postgres
############
# Supavisor -- Database pooler
############
POOLER_PROXY_PORT_TRANSACTION=CHANGEME
POOLER_DEFAULT_POOL_SIZE=CHANGEME
POOLER_MAX_CLIENT_CONN=CHANGEME
POOLER_TENANT_ID=CHANGEME
############
# API Proxy - Configuration for the Kong Reverse proxy.
############
KONG_HTTP_PORT=CHANGEME
KONG_HTTPS_PORT=CHANGEME
############
# API - Configuration for PostgREST.
############
PGRST_DB_SCHEMAS=CHANGEME
############
# Auth - Configuration for the GoTrue authentication server.
############
## General
SITE_URL=CHANGEME
ADDITIONAL_REDIRECT_URLS=CHANGEME
JWT_EXPIRY=CHANGEME
DISABLE_SIGNUP=CHANGEME
API_EXTERNAL_URL=CHANGEME
## Mailer Config
MAILER_URLPATHS_CONFIRMATION=CHANGEME
MAILER_URLPATHS_INVITE=CHANGEME
MAILER_URLPATHS_RECOVERY=CHANGEME
MAILER_URLPATHS_EMAIL_CHANGE=CHANGEME
## Email auth
ENABLE_EMAIL_SIGNUP=CHANGEME
ENABLE_EMAIL_AUTOCONFIRM=CHANGEME
SMTP_ADMIN_EMAIL=CHANGEME
SMTP_HOST=CHANGEME
SMTP_PORT=CHANGEME
SMTP_USER=CHANGEME
SMTP_PASS=CHANGEME
SMTP_SENDER_NAME=CHANGEME
ENABLE_ANONYMOUS_USERS=CHANGEME
## Phone auth
ENABLE_PHONE_SIGNUP=CHANGEME
ENABLE_PHONE_AUTOCONFIRM=CHANGEME
############
# Studio - Configuration for the Dashboard
############
STUDIO_DEFAULT_ORGANIZATION=CHANGEME
STUDIO_DEFAULT_PROJECT=CHANGEME
STUDIO_PORT=CHANGEME
# replace if you intend to use Studio outside of localhost
SUPABASE_PUBLIC_URL=CHANGEME
# Enable webp support
IMGPROXY_ENABLE_WEBP_DETECTION=CHANGEME
# Add your OpenAI API key to enable SQL Editor Assistant
#OPENAI_API_KEY="***REMOVED-OPENROUTER-KEY***"
OPENAI_API_KEY=CHANGEME
############
# Functions - Configuration for Functions
############
# NOTE: VERIFY_JWT applies to all functions. Per-function VERIFY_JWT is not supported yet.
FUNCTIONS_VERIFY_JWT=CHANGEME
# Netmaker — consumed by the netmaker-call edge function (direct Netmaker provisioning)
NETMAKER_BASE_URL=CHANGEME
NETMAKER_MASTER_KEY=CHANGEME
############
# Logs - Configuration for Analytics
# Please refer to https://supabase.com/docs/reference/self-hosting-analytics/introduction
############
# Change vector.toml sinks to reflect this change
# these cannot be the same value
LOGFLARE_PUBLIC_ACCESS_TOKEN=CHANGEME
LOGFLARE_PRIVATE_ACCESS_TOKEN=CHANGEME
# Docker socket location - this value will differ depending on your OS
DOCKER_SOCKET_LOCATION=CHANGEME
# Google Cloud Project details
GOOGLE_PROJECT_ID=CHANGEME
GOOGLE_PROJECT_NUMBER=CHANGEME
############
# Webhook Configuration for Database Reset Script
# Get these values from your Supabase Dashboard:
# 1. SUPABASE_ACCESS_TOKEN: https://supabase.com/dashboard/account/tokens (Generate new token)
# 2. SUPABASE_PROJECT_REF: Your project URL https://<PROJECT_REF>.supabase.co or Dashboard → Settings → General → Reference ID
# 3. SUPABASE_ANON_KEY: Use the ANON_KEY value above
############
SUPABASE_ACCESS_TOKEN=CHANGEME
SUPABASE_PROJECT_REF=CHANGEME
KESTRA_BASE_URL=CHANGEME
KESTRA_USER=CHANGEME
KESTRA_PASSWORD=CHANGEME
DB_ENC_KEY=CHANGEME
MINIO_ROOT_USER=CHANGEME
MINIO_ROOT_PASSWORD=CHANGEME
