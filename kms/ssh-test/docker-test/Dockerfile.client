# SSH Client for testing KMS-generated keys
FROM alpine:3.19

RUN apk add --no-cache openssh-client

# Create test user
RUN adduser -D -s /bin/sh testuser && \
    mkdir -p /home/testuser/.ssh && \
    chmod 700 /home/testuser/.ssh && \
    chown -R testuser:testuser /home/testuser/.ssh

# Add SSH config to disable strict host checking for testing
RUN echo -e "Host *\n  StrictHostKeyChecking no\n  UserKnownHostsFile /dev/null\n  LogLevel ERROR" > /home/testuser/.ssh/config && \
    chmod 600 /home/testuser/.ssh/config && \
    chown testuser:testuser /home/testuser/.ssh/config

USER testuser
WORKDIR /home/testuser

CMD ["sh"]
