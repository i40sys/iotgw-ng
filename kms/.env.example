# Cosmian KMS Environment Variables
# Copy this file to .env and customize as needed:
#   cp .env.example .env

# ============================================================================
# LOGGING
# ============================================================================

# Rust logging level for the KMS server
# Options: trace, debug, info, warn, error
# Default: info
RUST_LOG=info

# ============================================================================
# KMS SERVER (used by docker-compose)
# ============================================================================

# KMS server port (default: 9998)
# KMS_PORT=9998

# KMS server hostname (default: 0.0.0.0)
# KMS_HOSTNAME=0.0.0.0

# ============================================================================
# KMS CLI CONFIGURATION
# ============================================================================

# KMS server URL for CLI commands
# Used when running: ./contrib/cosmian kms <command>
KMS_DEFAULT_URL=http://localhost:9998

# Path to CLI configuration file (optional)
# Default: ~/.cosmian/cosmian.toml
# COSMIAN_CLI_CONF_PATH=/path/to/cosmian.toml

# ============================================================================
# AUTHENTICATION (optional, for production)
# ============================================================================

# JWT/OIDC settings (uncomment for authenticated access)
# KMS_JWT_ISSUER=https://your-auth-provider.com
# KMS_OIDC_CLIENT_ID=your-client-id

# ============================================================================
# TLS/SSL (optional, for production)
# ============================================================================

# Enable TLS for the KMS server
# KMS_TLS_CERT=/path/to/cert.pem
# KMS_TLS_KEY=/path/to/key.pem

# ============================================================================
# DATABASE (optional, default is SQLite)
# ============================================================================

# For production, consider PostgreSQL or MySQL
# KMS_DATABASE_TYPE=postgresql
# KMS_DATABASE_URL=postgres://user:password@host:5432/kms

# ============================================================================
# NOTES
# ============================================================================
#
# This file contains environment variables for:
# 1. The KMS server running in Docker (via docker-compose.yml)
# 2. The Cosmian CLI tools (./contrib/cosmian)
#
# For more configuration options, see:
# - kms.toml - Server configuration file
# - https://docs.cosmian.com/key_management_system/
